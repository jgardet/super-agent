# ─────────────────────────────────────────────────────────────────────────────
# Super-Agent · Environment
# cp .env.example .env   — then edit as needed
# For cloud mode (default): NO edits required. Just run docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Model mode ────────────────────────────────────────────────────────────────
# "cloud"  → GLM-5.1:cloud via Ollama proxy (free, no GPU needed, default)
# "local"  → LOCAL_MODEL served on your RTX 4080 12 GB
MODEL_MODE=cloud

CLOUD_MODEL=glm-5.1:cloud

# Best local models for RTX 4080 12 GB:
#   glm-4.7-flash   ~8 GB  MoE 30B/3B active  best all-round + tool-calling
#   qwen3-coder:14b ~9 GB  14B dense           best for heavy coding
#   qwen3.5:9b      ~6 GB  9B dense            fastest, lowest VRAM
LOCAL_MODEL=glm-4.7-flash

# Active model used by all services (auto-managed by switch-model.sh)
ACTIVE_MODEL=glm-5.1:cloud

# ── API keys (all optional) ───────────────────────────────────────────────────
# Anthropic key → enables Claude as reasoning fallback in orchestrator
# Set use_reasoning_llm=true in POST /run to activate
ANTHROPIC_API_KEY=

# OpenAI key → optional, used by OpenClaw if configured
OPENAI_API_KEY=

# Tavily key → enables live web search in the research crew
# Get a free key at https://tavily.com (1000 searches/month)
TAVILY_API_KEY=

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme

# ── OpenClaw messaging channels (all optional) ────────────────────────────────
# Enable channels by adding tokens — the gateway activates them automatically
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ── Orchestrator tuning ───────────────────────────────────────────────────────
# Number of parallel crew workers (default: 4)
ORCHESTRATOR_WORKERS=4

# Sync mode timeout in seconds (default: 120)
ORCHESTRATOR_SYNC_TIMEOUT=120

# Default memory namespace for cross-session context (default: super-agent)
MEMORY_DEFAULT_USER=super-agent
